{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.jsx?",
    "**/*.jsx?",
    "**/*.jsx?",
    ".next/types/**/*.jsx?",
    "app/ConvexClientProvider.jsx",
    "convex/users.js",
    "convex/auth.config.jsx?",
    "lib/inngest/functions.js",
    "app/api/inngest/route.js",
    "lib/inngest/client.js",
    "app/dashboard/layout.jsx",
    "app/dashboard/contacts/page.jsx",
    "components/Contactlayout.jsx",
    "components/ui/sonner.jsx",
    "components/dashboard/dasboardComponents/DashboardLayout.jsx",
    "lib/inngest/payment-reminders.js",
    "app/layout.jsx",
    "app/page.jsx",
    "components/dashboard/EmailInputField.jsx",
    "components/dashboard/InviteFriendsForm.jsx",
    "components/dashboard/Navbar.jsx",
    "components/dashboard/Sidebar.jsx",
    "components/ui/avatar.jsx",
    "components/ui/badge.jsx",
    "components/ui/button.jsx",
    "components/ui/card.jsx",
    "components/LandingComponent/AboutUs.jsx",
    "app/dashboard/page.jsx",
    "app/invite-friends/page.jsx",
    "components/LandingComponent/Feature.jsx",
    "components/LandingComponent/Footer.jsx",
    "components/LandingComponent/HeroSection.jsx",
    "components/LandingComponent/Navbar.jsx",
    ".next/dev/types/**/*.jsx?"
  ],
  "exclude": [
    "node_modules"
  ]
}